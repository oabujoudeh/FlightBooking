{% extends "base.peb" %}

{% block title %}Profile - EAJO Air{% endblock %}

{% block content %}

{% if loggedIn %}

<h2>Your Profile</h2>

<article>
    <p><strong>Username:</strong> {{ username }}</p>
</article>

<h3>Your Bookings</h3>

{% if bookings is empty %}
    <p>You have no bookings yet.</p>
{% else %}
    {% for booking in bookings %}
    <article>
        <p><strong>Booking #{{ booking.bookingId }}</strong></p>
        <p>Date: {{ booking.bookingDate }}</p>
        <p>Status: {{ booking.status }}</p>
        <p>Total Price: £{{ booking.totalPrice }}</p>

        {% for flight in booking.flights %}
        <p>{{ flight.flightNumber }}: {{ flight.departureCity }} → {{ flight.arrivalCity }}</p>
        <p>{{ flight.departureDate }} | {{ flight.departureTime }} → {{ flight.arrivalTime }} | {{ flight.duration }}</p>
        {% endfor %}

        <a href="/edit-booking?id={{ booking.bookingId }}" role="button" class="outline">Edit Booking</a>
    </article>
    {% endfor %}
{% endif %}

<a href="/" role="button" class="secondary" aria-label="Remove your account">Remove account</a>
<a href="/logout" role="button" class="outline" aria-label="Log out of your account">Logout</a>

{% endif %}

{% endblock %}
