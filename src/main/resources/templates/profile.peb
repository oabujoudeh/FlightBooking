{% extends "base.peb" %}

{% block title %}Profile - JOEAir{% endblock %}

{% block content %}
<h2>Your Profile</h2>

{% if loggedIn %}

    <article>
        <p><strong>Username:</strong> {{ username }}</p>
    </article>

    <a href="/" role="button" class="secondary">Remove account</a>
    <a href="/logout" role="button" class="outline">Logout</a>

{% endif %}

{% endblock %}
