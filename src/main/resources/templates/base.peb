<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light">
    <title>{% block title %}EAJO Air{% endblock %}</title>
    <link rel="stylesheet" href="/static/style.css">
    {% block head %}{% endblock %}
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav class="navbar" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="EAJO Air home page">✈ EAJO Air</a>

    <div class="navbar-right">
        {% if not isAdmin %}
        <div class="noti-wrap">
            <button type="button" onclick="toggleNoti()" class="noti-btn">
                Notifications
                <span id="noti-dot" class="noti-dot"></span>
            </button>
            <div id="noti-box" class="noti-box">
                <p class="noti-box-header">Messages</p>
                <div class="noti-scroll">
                    {% if notifications is not empty %}
                        {% for note in notifications %}
                        <div id="noti-item-{{ loop.index }}" class="noti-item">
                            <span>Your <strong>{{ note.type }}</strong> request was <span class="noti-status-{{ note.status }}">{{ note.status }}</span>.</span>
                            <button onclick="markRead({{ loop.index }})" id="read-btn-{{ loop.index }}" class="noti-mark-read">Mark read</button>
                        </div>
                        {% endfor %}
                    {% else %}
                        <p class="noti-empty">No notifications</p>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endif %}
        {% if loggedIn %}
            {% if not isAdmin %}
            <a href="/complaint" class="auth-btn">Complaint</a>
            {% endif %}
            <a href="/profile" class="auth-btn">Profile</a>
        {% else %}
            <a href="/login" class="auth-btn">Login</a>
        {% endif %}
    </div>
</nav>
<script>
function toggleNoti() {
    var box = document.getElementById('noti-box');
    if (box) box.style.display = box.style.display === 'none' ? 'block' : 'none';
}

window.onclick = function(event) {
    if (!event.target.closest('.navbar')) {
        var box = document.getElementById('noti-box');
        if (box) box.style.display = 'none';
    }
}

function markRead(index) {
    const item = document.getElementById('noti-item-' + index);
    if (!item) return;

    const content = item.querySelector('span').innerText;

    let dismissed = JSON.parse(localStorage.getItem('dismissed_notis') || '[]');
    if (!dismissed.includes(content)) {
        dismissed.push(content);
        localStorage.setItem('dismissed_notis', JSON.stringify(dismissed));
    }

    item.remove();
    updateUIState();
}

function updateUIState() {
    const dismissed = JSON.parse(localStorage.getItem('dismissed_notis') || '[]');
    const items = document.querySelectorAll('[id^="noti-item-"]');

    items.forEach(item => {
        const content = item.querySelector('span').innerText;
        if (dismissed.includes(content)) item.remove();
    });

    const remaining = document.querySelectorAll('[id^="noti-item-"]');
    const dot = document.getElementById('noti-dot');

    if (remaining.length > 0) {
        if (dot) dot.style.display = 'block';
    } else {
        if (dot) dot.style.display = 'none';
        const container = document.querySelector('#noti-box .noti-scroll');
        if (container && !container.querySelector('p')) {
            container.innerHTML = '<p class="noti-empty">No notifications</p>';
        }
    }
}

document.addEventListener('DOMContentLoaded', updateUIState);
</script>
<main id="main-content">
    {% block content %}{% endblock %}
</main>
</body>
</html>
