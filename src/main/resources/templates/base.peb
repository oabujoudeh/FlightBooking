<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>{% block title %}EAJO Air{% endblock %}</title>
    <link rel="stylesheet" href="/static/style.css">
    {% block head %}{% endblock %}
</head>
<body>
<nav class="navbar">
    <a href="/" class="logo">✈ EAJO Air</a>
    {% if loggedIn %}
        <a href="/my-bookings" class="auth-btn">My Bookings</a>
        <a href="/profile" class="auth-btn">Profile</a>
    {% else %}
        <a href="/login" class="auth-btn">Login</a>
    {% endif %}
</nav>
<main>
    {% block content %}{% endblock %}
</main>
</body>
</html>
