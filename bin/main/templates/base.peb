<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>{% block title %}EAJO Air{% endblock %}</title>
    <link rel="stylesheet" href="/static/style.css">
    <style>
        .skip-link {
            position: absolute;
            left: -9999px;
            top: 0;
            z-index: 999;
            padding: 8px 16px;
            background: #000;
            color: #fff;
        }
        .skip-link:focus {
            left: 0;
        }
        *:focus {
            outline: 2px solid #005fcc;
            outline-offset: 2px;
        }
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0,0,0,0);
            white-space: nowrap;
            border: 0;
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav class="navbar" aria-label="Main navigation">
    <a href="/" class="logo" aria-label="EAJO Air home page">✈ EAJO Air</a>
    {% if loggedIn %}
        <a href="/profile" class="auth-btn">Profile</a>
    {% else %}
        <a href="/login" class="auth-btn">Login</a>
    {% endif %}
</nav>
<main id="main-content">
    {% block content %}{% endblock %}
</main>
</body>
</html>
